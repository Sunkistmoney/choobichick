generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Sex {
  hen
  rooster
}

enum ChickenStatus {
  active
  sold
  deceased
}

model Chicken {
  id               String            @id @default(uuid())
  tagId            String            @unique
  breed            String
  sex              Sex
  birthDate        DateTime
  weight           Float?
  status           ChickenStatus     @default(active)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  feedingSchedules FeedingSchedule[]
}

enum InventoryCategory {
  feed
  vitamins
  medicine
  vaccine
  supplies
}

model InventoryItem {
  id                String            @id @default(uuid())
  name              String
  category          InventoryCategory
  quantity          Float
  unit              String
  lowStockThreshold Float
  expiryDate        DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum ExpenseCategory {
  feed
  vitamins
  medicine
  utilities
  equipment
  labor
  other
}

model EggSale {
  id           String   @id @default(uuid())
  date         DateTime
  boxesSold    Int
  piecesPerBox Int      @default(100)
  pricePerBox  Float
  totalRevenue Float
  buyer        String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Expense {
  id          String          @id @default(uuid())
  date        DateTime
  category    ExpenseCategory
  description String
  amount      Float
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EggProduction {
  id             String   @id @default(uuid())
  date           DateTime
  totalEggs      Int
  brokenEggs     Int      @default(0)
  unsellableEggs Int      @default(0)
  sellableEggs   Int
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  passwordHash  String
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FeedingSchedule {
  id          String   @id @default(uuid())
  chickenId   String
  chicken     Chicken  @relation(fields: [chickenId], references: [id], onDelete: Cascade)
  feedType    String
  quantity    Float
  unit        String
  feedingTime String
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
