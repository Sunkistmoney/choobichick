# Neon (or any Postgres) pooled connection — used at runtime by the app
DATABASE_URL="postgresql://USER:PASSWORD@HOST/chb_poultry?sslmode=require"

# Neon direct (non-pooled) connection — used by Prisma CLI for migrations
DIRECT_URL="postgresql://USER:PASSWORD@direct.HOST/chb_poultry?sslmode=require"

# NextAuth secret — generate with: openssl rand -hex 32
AUTH_SECRET="your-secret-here"
